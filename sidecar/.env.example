# hseal-sidecar config (env only; never commit real values)

# The provider identity, a CAIP-10 you control. For XRPL the account MUST be
# ed25519 (the H-Seal server derives the r-address from the 0xED ed25519 pubkey;
# a default secp256k1 XRPL account will NOT verify). A hedera:mainnet:0.0.x
# ed25519 key is the simplest choice.
PROVIDER_IDENTITY=

# The 32-byte ed25519 seed (hex) matching PROVIDER_IDENTITY, or an EVM private key
# when PROVIDER_KEY_TYPE=evm.
PROVIDER_KEY_RAW=

# ed25519 (default) | evm
PROVIDER_KEY_TYPE=ed25519

# mainnet (default) | testnet
HSEAL_NETWORK=mainnet

# Optional shared-secret bearer token. When set, /attest and /sign-receipt require
# `Authorization: Bearer <token>`. Leave unset ONLY if the sidecar is bound to a
# private network / localhost that callers alone can reach.
SIDECAR_AUTH_TOKEN=

# Listen port.
PORT=8791
