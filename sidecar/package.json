{
  "name": "hseal-sidecar",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "HTTP signing sidecar over @xr-utilities/h-seal-provider: POST /attest and /sign-receipt so a non-Node service (Python/FastAPI, etc.) can co-sign H-Seal receipts with the real SDK.",
  "scripts": {
    "dev": "tsx watch server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@xr-utilities/h-seal-provider": "github:XR-Utilities/h-seal-provider#v0.1.0",
    "@hono/node-server": "^1.13.0",
    "hono": "^4.6.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=20"
  }
}
